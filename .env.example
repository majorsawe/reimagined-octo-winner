# Deriv Matcher Configuration
# No API keys required for simulation mode

# Scanning Configuration
SCAN_INTERVAL=5000  # milliseconds (5 seconds)
DURATION=60         # seconds (60 seconds total)
TOTAL_SCANS=12      # Computed as DURATION / (SCAN_INTERVAL / 1000)

# Markets (Read-only - all digit markets are scanned)
# R_100, R_50, R_25, RDBULL, RDBEAR

# Analysis Configuration
HISTORY_WINDOW=60   # seconds
MIN_EXPIRATION=5    # seconds
MAX_EXPIRATION=300  # seconds

# Output
GENERATE_JSON_REPORT=true
REPORT_FILENAME=prediction_report.json
